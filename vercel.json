{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/install",
      "dest": "/public/install.html"
    },
    {
      "src": "/yantra-extension.crx",
      "dest": "/public/yantra-extension.crx",
      "headers": {
        "Content-Type": "application/x-chrome-extension",
        "Content-Disposition": "attachment; filename=yantra-extension.crx"
      }
    },
    {
      "src": "/",
      "dest": "/public/install.html"
    }
  ]
}
