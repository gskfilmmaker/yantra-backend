{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/install", "destination": "/install.html" },
    { "source": "/yantra-extension.crx", "destination": "/yantra-extension.crx" }
  ],
  "headers": [
    {
      "source": "/yantra-extension.crx",
      "headers": [
        { "key": "Content-Type", "value": "application/x-chrome-extension" },
        { "key": "Content-Disposition", "value": "attachment; filename=yantra-extension.crx" }
      ]
    }
  ]
}
